services:
  ftp:
    image: fauria/vsftpd
    container_name: skewt-ftp
    restart: unless-stopped
    env_file:
      - ./config/wireguard-ftp.env
    environment:
      PASV_ENABLE: "YES"
      PASV_ADDRESS: "10.44.0.1"
      PASV_MIN_PORT: "30000"
      PASV_MAX_PORT: "30009"
    volumes:
      - ./data/work:/home/vsftpd/radiosonde
    ports:
      - "10.44.0.1:21:21"
      - "10.44.0.1:30000-30009:30000-30009"
